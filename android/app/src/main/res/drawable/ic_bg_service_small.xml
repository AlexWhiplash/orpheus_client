<?xml version="1.0" encoding="utf-8"?>
<!--
  Иконка постоянного foreground-сервиса (flutter_background_service ищет
  drawable с именно этим именем; без него плагин берёт лончер-иконку — лист,
  который светился в статусбаре, device-тест 13.07.2026).

  Тот же монохромный щит, что и ic_stat_orpheus — единый стиль во всех
  статусбар-иконках (сервис, уведомления, звонки).

  ВАЖНО: плагин flutter_background_service_android поставляет СВОЙ
  ic_bg_service_small.png в density-папках (drawable-hdpi/mdpi/xhdpi/xxhdpi).
  Этот generic vector density-specific PNG плагина НЕ перебивает (Android для
  конкретной плотности предпочитает density-match). Поэтому наш щит лежит ещё и
  как PNG в drawable-{mdpi..xxxhdpi}/ic_bg_service_small.png — они перебивают
  плагинские (app res > library res). Vector оставлен как fallback.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,2 L20,5 L20,11 C20,16.5 16.5,20.8 12,22 C7.5,20.8 4,16.5 4,11 L4,5 Z" />
</vector>
