<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) правила извлечения данных.
  Секретный мессенджер: НЕ отдаём данные приложения ни в облачный бэкап,
  ни в device-to-device перенос (даже зашифрованная БД и Keystore не должны
  покидать устройство). См. AUDIT_REPORT SEC-7 / DB-2 / OPS-3.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
